# ============================================================
# CYBER PORTAL — Environment Variables
# Copy to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Database (Neon PostgreSQL) ────────────────────────────────
# Use the POOLED connection string from Neon
DATABASE_URL="postgresql://neondb_owner:SENHA@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ── JWT ───────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET="replace-with-min-32-char-random-secret"

# ── App ───────────────────────────────────────────────────────
NODE_ENV="development"
