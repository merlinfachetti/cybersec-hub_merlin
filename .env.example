# ============================================================
# CYBER PORTAL — Environment Variables
# Copy to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Standard connection (used by app at runtime)
DATABASE_URL="postgresql://USER:PASS@HOST:PORT/DATABASE"

# Direct connection (used by Prisma for migrations)
# For Neon: use the non-pooled connection string
# For local dev: same as DATABASE_URL
DIRECT_URL="postgresql://USER:PASS@HOST:PORT/DATABASE"

# ── JWT ──────────────────────────────────────────────────────
# Min 32 chars. Generate: openssl rand -base64 32
JWT_SECRET="replace-with-min-32-char-random-secret"

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
